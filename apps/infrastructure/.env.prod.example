MILKBOT_KEY=your-production-milkbot-key

STORAGE_ACCOUNT_NAME_ICAR=your-icar-storage-account
STORAGE_ACCOUNT_KEY_ICAR=your-icar-storage-key
STORAGE_ACCOUNT_CONTAINER_ICAR=your-icar-container

# Optional locally, required for authenticated GHCR pulls in Azure Container Apps.
GHCR_USERNAME=your-github-username
GHCR_TOKEN=your-classic-pat-with-read-packages

