PULUMI_CONFIG_PASSPHRASE=your-passphrase

# Pulumi state backend (azblob://pulumi-state)
# Stored in rg-bovi-state — separate from managed infrastructure
AZURE_STORAGE_ACCOUNT_STATE=bovistatesa
AZURE_STORAGE_KEY=your-storage-key

# Preset dataset blob storage used by the central API.
STORAGE_ACCOUNT_NAME_ICAR=your-icar-storage-account
STORAGE_ACCOUNT_KEY_ICAR=your-icar-storage-key
STORAGE_ACCOUNT_CONTAINER_ICAR=your-icar-container
