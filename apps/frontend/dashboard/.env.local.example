# The dashboard server proxy reads API_URL at runtime.
# Root `just dev` sets this automatically from /.env; only set it here when
# running the dashboard directly from this directory.
# API_URL=http://localhost:8000
AZURE_AD_CLIENT_ID=
AZURE_AD_API_SCOPE=
AUTH_REDIRECT_URI=http://localhost:3000/auth/login
AUTH_POST_LOGOUT_REDIRECT_URI=http://localhost:3000
AUTH_DISABLED=false
