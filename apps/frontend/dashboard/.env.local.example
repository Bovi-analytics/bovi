# The dashboard server proxy reads NEXT_PUBLIC_API_URL at runtime.
# Root `just dev` sets this automatically from /.env; only set it here when
# running the dashboard directly from this directory.
# NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_AZURE_AD_CLIENT_ID=
NEXT_PUBLIC_AZURE_AD_API_SCOPE=
NEXT_PUBLIC_AUTH_DISABLED=false
NEXT_PUBLIC_DEV_MODE=false
