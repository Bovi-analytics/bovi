# Ports and derived URLs (LACTATION_CURVES_URL, CORS_ORIGINS, etc.)
# are set by the root justfile from /.env — do not duplicate here.

# SQLite (default for local dev): stored as a file next to the API process.
DATABASE_URL=sqlite+aiosqlite:///./bovi.db

# Azure/prod uses SQLite persisted on Azure Files, typically mounted at /data:
# DATABASE_URL=sqlite+aiosqlite:////data/bovi.db

# Optional: SQLAlchemy can still connect to PostgreSQL when explicitly configured.
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/bovi
