# Ports and derived URLs (LACTATION_CURVES_URL, CORS_ORIGINS, etc.)
# are set by the root justfile from /.env — do not duplicate here.

# SQLite (default for local dev): stored as a file next to the API process.
DATABASE_URL=sqlite+aiosqlite:///./bovi.db

# Azure/prod uses SQLite persisted on Azure Files with dotfile locking:
# DATABASE_URL=sqlite+aiosqlite:///file:/mnt/data/bovi.db?vfs=unix-dotfile&uri=true

# Optional: SQLAlchemy can still connect to PostgreSQL when explicitly configured.
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/bovi

# Microsoft Entra access-token validation. The API accepts work/school and
# personal Microsoft accounts from any tenant, but Bovi organization access is
# controlled by local memberships and invites.
AZURE_AD_CLIENT_ID=
AUTH_DISABLED=false
