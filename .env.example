# ── Port assignments (single source of truth) ────────────────
PORT_API=8000
PORT_CURVES=8001
PORT_AUTOENCODER=8002
PORT_DASHBOARD=3000

# ── Central API database ─────────────────────────────────────
# Local dev uses a SQLite file. Azure/prod uses SQLite on Azure Files,
# mounted into the API container and configured in infrastructure code.
DATABASE_URL=sqlite+aiosqlite:///./bovi.db

# ── API keys ─────────────────────────────────────────────────
MILKBOT_KEY=your_milkbot_key
PYPI_TOKEN=your_pypi_token

# ── Azure / Infrastructure ───────────────────────────────────
STORAGE_ACCOUNT_KEY_ICAR=your_storage_account_key
STORAGE_ACCOUNT_NAME_ICAR=your_storage_account_name
STORAGE_ACCOUNT_CONTAINER_ICAR=your_storage_account_container

STORAGE_ACCOUNT_KEY_PLAYBEHAVIOR=your_storage_account_key

# ── Autoencoder model assets ─────────────────────────────────
# Required when the local /tmp/bovi-autoencoder-assets cache is empty.
AzureWebJobsStorage=DefaultEndpointsProtocol=https;AccountName=your_model_assets_account;AccountKey=your_model_assets_key;EndpointSuffix=core.windows.net
AUTOENCODER_MODEL_CONTAINER=model-assets
AUTOENCODER_MODEL_PREFIX=data/models/lactation_autoencoder/versions/v15
AUTOENCODER_MODEL_CACHE_DIR=/tmp/bovi-autoencoder-assets

AZURE_STORAGE_ACCOUNT_STATE=
AZURE_STORAGE_KEY_STATE=

DATABRICKS_TOKEN=your_databricks_token
PULUMI_PASSPHRASE=token

AZURE_CLIENT_ID=your_azure_client_id
AZURE_SECRET_VALUE=your_azure_secret_value
AZURE_TENANT_ID=your_azure_tenant_id
